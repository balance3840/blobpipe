{
  "name": "@blobpipe/s3",
  "version": "0.1.0",
  "description": "Amazon S3 (and S3-compatible) driver for blobpipe.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "storage",
    "blob",
    "s3",
    "gcs",
    "azure",
    "file-storage",
    "blobpipe",
    "aws"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ramirohococo/blobpipe.git"
  },
  "bugs": {
    "url": "https://github.com/ramirohococo/blobpipe/issues"
  },
  "homepage": "https://github.com/ramirohococo/blobpipe#readme",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@blobpipe/core": "workspace:*"
  },
  "peerDependencies": {
    "@aws-sdk/client-s3": ">=3.0.0",
    "@aws-sdk/lib-storage": ">=3.0.0",
    "@aws-sdk/s3-request-presigner": ">=3.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/lib-storage": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@types/node": "^22.20.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "sideEffects": false
}
