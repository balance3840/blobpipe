{
  "name": "@blobpipe/core",
  "version": "0.1.0",
  "description": "Core abstractions for blobpipe \u2014 types, StorageClient, middleware, errors, and utilities.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./middleware": {
      "types": "./dist/middleware/index.d.ts",
      "import": "./dist/middleware/index.js",
      "require": "./dist/middleware/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "storage",
    "blob",
    "s3",
    "gcs",
    "azure",
    "file-storage",
    "blobpipe"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ramirohococo/blobpipe.git"
  },
  "bugs": {
    "url": "https://github.com/ramirohococo/blobpipe/issues"
  },
  "homepage": "https://github.com/ramirohococo/blobpipe#readme",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "file-type": ">=18"
  },
  "peerDependenciesMeta": {
    "file-type": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.20.0",
    "file-type": "^22.0.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "sideEffects": false
}
