{
  "name": "@blobpipe/azure-blob",
  "version": "0.1.0",
  "description": "Azure Blob Storage driver for blobpipe.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "keywords": [
    "storage",
    "blob",
    "s3",
    "gcs",
    "azure",
    "file-storage",
    "blobpipe",
    "azure"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/balance3840/blobpipe.git"
  },
  "bugs": {
    "url": "https://github.com/balance3840/blobpipe/issues"
  },
  "homepage": "https://github.com/balance3840/blobpipe#readme",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=18.17"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@blobpipe/core": "workspace:*"
  },
  "peerDependencies": {
    "@azure/core-auth": ">=1.0.0",
    "@azure/storage-blob": ">=12.0.0",
    "@azure/identity": "^4.13.1"
  },
  "peerDependenciesMeta": {
    "@azure/identity": {
      "optional": true
    }
  },
  "devDependencies": {
    "@azure/core-auth": "^1.10.0",
    "@azure/identity": "^4.13.1",
    "@azure/storage-blob": "^12.26.0",
    "@types/node": "^22.20.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2"
  },
  "sideEffects": false
}
