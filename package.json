{
  "name": "blobpipe-workspace",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:packages": "pnpm -r test",
    "test:emulators": "vitest run --config vitest.emulators.config.ts",
    "lint": "eslint packages",
    "play": "tsx playground.ts",
    "play:azure": "tsx playground-azure.ts",
    "play:s3": "tsx playground-s3.ts",
    "play:memory": "tsx playground-memory.ts",
    "play:gcs": "tsx playground-gcs.ts"
  },
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=18.17"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@azure/identity": "^4.13.1",
    "@changesets/changelog-git": "^0.2.0",
    "@changesets/cli": "^2.31.0",
    "@google-cloud/storage": "^7.21.0",
    "@types/node": "^22.20.0",
    "eslint": "^9.17.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitepress": "^1.5.0",
    "vitest": "^2.1.9"
  }
